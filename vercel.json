{
  "version": 2,
  "functions": {
    "api/generate.py": {
      "runtime": "@vercel/python@4.3.0",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "templates/**"
    }
  },
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "cleanUrls": true
}
