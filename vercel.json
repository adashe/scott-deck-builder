{
    "version": 2,
    "functions": {
        "api/generate.py": {
            "runtime": "@vercel/python@4.3.0",
            "memory": 1024,
            "maxDuration": 60,
            "includeFiles": "templates/**"
        }
    },
    "rewrites": [
        {
            "source": "/css/:asset*",
            "destination": "/css/:asset*"
        },
        {
            "source": "/js/:asset*",
            "destination": "/js/:asset*"
        },
        {
            "source": "/scott-deck-builder/api/:path*",
            "destination": "/api/generate.py"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/generate.py"
        },
        {
            "source": "/scott-deck-builder/:path*",
            "destination": "/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "cleanUrls": true
}
